--- a/packages/PyTrilinos/src/CMakeLists.txt
+++ b/packages/PyTrilinos/src/CMakeLists.txt
@@ -117,6 +117,27 @@
 IF(NOX_ENABLE_PETSC)
   INCLUDE_DIRECTORIES(${PETSC4PY_INCLUDES})
 ENDIF(NOX_ENABLE_PETSC)
+# Expose include dirs of every enabled upstream package to SWIG. Modern TriBITS
+# propagates these via target_include_directories(PUBLIC), which is not visible
+# to GET_DIRECTORY_PROPERTY(INCLUDE_DIRECTORIES) used inside UseSWIG.cmake.
+# Recursively find all headers in source + binary trees and add their parent
+# directories.
+FILE(GLOB_RECURSE _pytri_all_headers
+  "${PROJECT_SOURCE_DIR}/packages/*.h"
+  "${PROJECT_SOURCE_DIR}/packages/*.H"
+  "${PROJECT_SOURCE_DIR}/packages/*.hpp"
+  "${PROJECT_BINARY_DIR}/packages/*.h"
+  "${PROJECT_BINARY_DIR}/packages/*.hpp"
+  )
+SET(_pytri_real_dirs "")
+FOREACH(_h ${_pytri_all_headers})
+  GET_FILENAME_COMPONENT(_d "${_h}" DIRECTORY)
+  LIST(APPEND _pytri_real_dirs "${_d}")
+ENDFOREACH()
+LIST(REMOVE_DUPLICATES _pytri_real_dirs)
+IF(_pytri_real_dirs)
+  INCLUDE_DIRECTORIES(${_pytri_real_dirs})
+ENDIF()
 
